---
import PageLayout from "@/layouts/Base.astro";
import { getCollection } from "astro:content";
import { Schema } from "astro-seo-schema";

const siteUrl = (path: string) => new URL(path, Astro.site).toString();

const projects = (await getCollection("project", ({ data }) => import.meta.env.PROD ? !data.draft : true))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<Schema
	item={{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		itemListElement: [
			{ "@type": "ListItem", position: 1, name: "Accueil", item: siteUrl("/") },
			{ "@type": "ListItem", position: 2, name: "Projets", item: siteUrl("/projects") },
		],
	}}
/>

<PageLayout meta={{ title: "Projets" }}>
	<section class="work" aria-labelledby="work-label">
		<div class="section-label" id="work-label">Projets</div>
		<p class="intro">
			Sélection de projets — jeux Unity, expérimentations, prototypes.
		</p>
		<ul class="work-list">
			{projects.map((p) => (
				<li>
					<a href={`/projects/${p.id}/`}>
						<div class="head">
							<span class="name">{p.data.title}</span>
							{p.data.stack.length > 0 && (
								<span class="stack">{p.data.stack.join(" · ")}</span>
							)}
							{p.data.featured && <span class="badge">Featured</span>}
						</div>
						<p>{p.data.description}</p>
					</a>
				</li>
			))}
		</ul>
	</section>
</PageLayout>

<style>
	.work { margin-bottom: 88px; }
	.intro {
		font-family: var(--font-serif);
		font-size: 17.5px;
		line-height: 1.7;
		color: hsl(var(--theme-text));
		margin: 0 0 36px;
		max-width: 60ch;
		text-wrap: pretty;
	}
	@media (max-width: 720px) { .intro { font-size: 17px; margin-bottom: 28px; } }
	@media (max-width: 420px) {
		.work { margin-bottom: 56px; }
		.intro { font-size: 16.5px; }
	}
</style>
