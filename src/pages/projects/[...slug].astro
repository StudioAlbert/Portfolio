---
import PageLayout from "@/layouts/Base.astro";
import ProjectGallery from "@/components/project/ProjectGallery.astro";
import { getCollection, render } from "astro:content";
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";

export const getStaticPaths = (async () => {
	const projects = await getCollection("project", ({ data }) => import.meta.env.PROD ? !data.draft : true);
	return projects.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
const { entry } = Astro.props;
const { Content } = await render(entry);
const data = entry.data;

// Lien de secours sous la démo (l'embed peut être bloqué, ex. itch.io derrière Cloudflare).
const demoFallbackHref = data.demoFallbackUrl ?? data.demoUrl;
const isItch = demoFallbackHref?.includes("itch.io");
const demoFallbackLabel = isItch ? "Jouer sur itch.io →" : "Ouvrir dans un nouvel onglet →";
---

<PageLayout meta={{ title: data.title, description: data.description, ogImage: data.ogImage }}>
	<article class="project">
		<header>
			<h1>{data.title}</h1>
			<p class="desc">{data.description}</p>
			{data.stack.length > 0 && (
				<p class="stack">{data.stack.join(" · ")}</p>
			)}
			{(data.repoUrl || data.demoUrl) && (
				<p class="links">
					{data.repoUrl && <a href={data.repoUrl} rel="noreferrer" target="_blank">Repo</a>}
					{data.demoUrl && <a href={data.demoUrl} rel="noreferrer" target="_blank">Démo</a>}
				</p>
			)}
		</header>

		{data.demoUrl && (
			<div
				class:list={["demo", { "demo--fixed": data.demoHeight }]}
				style={data.demoHeight ? `height:${data.demoHeight}px` : undefined}
			>
				<iframe
					src={data.demoUrl}
					title={`Démo jouable — ${data.title}`}
					loading="lazy"
					allow="autoplay; fullscreen; gamepad *;"
					allowfullscreen
				></iframe>
			</div>
		)}

		{data.demoUrl && demoFallbackHref && (
			<p class="demo-fallback">
				L'aperçu ne se charge pas ?{" "}
				<a href={demoFallbackHref} rel="noreferrer" target="_blank">{demoFallbackLabel}</a>
			</p>
		)}

		{data.gallery.length > 0 && (
			<ProjectGallery media={data.gallery} title={data.title} />
		)}

		<div class="body">
			<Content />
		</div>
	</article>
</PageLayout>

<style>
	.project { margin-bottom: 64px; max-width: 760px; }
	/* Texte lisible (largeur de lecture) ; seule la démo occupe toute la largeur */
	.project > header,
	.project > .body { max-width: var(--reading-width); }
	.project h1 { font-family: var(--font-serif); font-size: 34px; font-weight: 600; line-height: 1.12; letter-spacing: -0.02em; margin: 0 0 10px; }
	.desc { font-family: var(--font-serif); font-size: 17.5px; line-height: 1.7; margin: 0 0 12px; }
	.stack { font-size: 14px; opacity: 0.75; margin: 0 0 8px; }
	.links { display: flex; gap: 16px; margin: 0 0 28px; }
	.demo {
		position: relative;
		width: 100%;
		aspect-ratio: 16 / 9;
		margin: 0 0 32px;
		border: 1px solid hsl(var(--theme-text) / 0.15);
		border-radius: 6px;
		overflow: hidden;
		background: hsl(var(--theme-text) / 0.04);
	}
	/* Démo à hauteur fixe (widgets verticaux) : on annule le ratio 16:9 */
	.demo--fixed { aspect-ratio: auto; }
	.demo iframe { width: 100%; height: 100%; border: 0; display: block; }
		.demo-fallback { font-size: 18px; opacity: 0.95; margin: -10px 0 36px; }
		.demo-fallback a { font-weight: 600; text-decoration: underline; }
	.body :global(p) { margin: 0 0 22px; }
	.body :global(img) { max-width: 100%; height: auto; border-radius: 4px; }
	/* Sous-titres de section (## …) — plus grands que le corps de texte */
	.body :global(h2) {
		font-family: var(--font-serif);
		font-size: 24px;
		font-weight: 600;
		line-height: 1.3;
		letter-spacing: -0.01em;
		margin: 40px 0 14px;
	}
	.body :global(h3) {
		font-family: var(--font-serif);
		font-size: 20px;
		font-weight: 600;
		line-height: 1.35;
		margin: 32px 0 10px;
	}
	/* Bloc d'intro (> …) — chapeau mis en valeur */
	.body :global(blockquote) {
		margin: 0 0 28px;
		padding: 2px 0 2px 18px;
		border-left: 3px solid hsl(var(--theme-accent) / 0.55);
		font-size: 19px;
		line-height: 1.6;
		color: hsl(var(--theme-text-muted));
	}
	.body :global(blockquote p) { margin: 0; }
	.body :global(blockquote strong) { color: hsl(var(--theme-text)); }

	@media (max-width: 420px) {
		.project h1 { font-size: 27px; }
		.body :global(h2) { font-size: 21px; margin: 32px 0 12px; }
		.body :global(h3) { font-size: 18px; }
		.body :global(blockquote) { font-size: 17px; }
	}
</style>
