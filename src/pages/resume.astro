---
import { getEntry, render } from "astro:content";
import PageLayout from "@/layouts/Base.astro";
import { siteConfig } from "@/site-config";

const entry = await getEntry("page", "resume");
if (!entry) throw new Error("Missing src/content/page/resume.md");
const { Content } = await render(entry);

const profile = siteConfig.profile;
const authorName = profile?.name ?? siteConfig.author;

const meta = {
	description: entry.data.description ?? `${authorName} — CV.`,
	title: entry.data.title,
};
---

<PageLayout meta={meta}>
	<section class="about" aria-labelledby="resume-label">
		<div class="section-label" id="resume-label">CV</div>
		<div class="bio">
			<Content />
		</div>
	</section>
</PageLayout>

<style>
	.about { margin-bottom: 64px; }
	.bio {
		font-family: var(--font-serif);
		font-size: 17.5px;
		line-height: 1.75;
		color: hsl(var(--theme-text));
		max-width: var(--reading-width);
	}
	.bio :global(h2) {
		font-family: var(--font-serif);
		font-size: 22px;
		margin: 32px 0 12px;
	}
	.bio :global(ul) {
		list-style: disc;
		list-style-position: inside;
		margin: 0 0 28px;
		padding: 0;
	}
	.bio :global(ul li) {
		margin-bottom: 6px;
		text-wrap: pretty;
	}
	.bio :global(p) { margin: 0 0 22px; text-wrap: pretty; }
	.bio :global(a) {
		color: hsl(var(--theme-text));
		text-decoration: underline;
		text-decoration-color: hsl(var(--theme-text) / 0.35);
		text-decoration-thickness: 1px;
		text-underline-offset: 3px;
	}
	.bio :global(a:hover) { color: hsl(var(--theme-accent)); }

	@media (max-width: 720px) { .bio { font-size: 17px; line-height: 1.7; } }
	@media (max-width: 420px) { .bio { font-size: 16.5px; } }
</style>
